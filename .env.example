# PaySync — https://usepaysync.com/documentacao
# Nunca commite o ficheiro .env (está no .gitignore).

# Chave API (ps_live_… produção ou ps_test_… sandbox)
PAYSYNC_API_KEY=

# Opcional: se definir, o webhook só aceita ?token=… (recomendado em produção)
PAYSYNC_WEBHOOK_TOKEN=

# Opcional: base da API (predefinido https://api.usepaysync.com/api/v1)
# PAYSYNC_API_BASE=https://api.usepaysync.com/api/v1

# URL pública da loja (HTTPS obrigatório para callback PaySync; em local use polling)
PUBLIC_BASE_URL=http://127.0.0.1:3000

PORT=3000
SESSION_SECRET=troque-em-producao

# Produção: NODE_ENV=production (mensagens de erro genéricas, trust proxy se TRUST_PROXY=1)
# HTTPS: COOKIE_SECURE=1 para cookie de sessão só em canal seguro
# NODE_ENV=production
# TRUST_PROXY=1
# COOKIE_SECURE=1

# Frete fixo “Padrão” (centavos), ex.: 8000 = R$ 80,00
FREIGHT_PADRAO_CENTS=8000
