# Frontend (Vite) + Supabase
# Copie para ".env.local" e preencha os valores do seu projeto Supabase.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Opcional (exemplo): URL pública usada por integrações cliente.
# VITE_PUBLIC_BASE_URL=http://localhost:5173

# --- Supabase Edge Functions (configure as project secrets, not in frontend) ---
# PAYMENT_PROVIDER_BASE_URL=
# PAYMENT_PROVIDER_API_KEY=
