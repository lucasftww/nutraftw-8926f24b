# Frontend (Vite) + Supabase
# Copie para ".env.local" e preencha os valores do seu projeto Supabase.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Opcional (exemplo): URL pública usada por integrações cliente.
# VITE_PUBLIC_BASE_URL=http://localhost:5173

# Opcional: Sentry error reporting. Sem DSN, o SDK NÃO é carregado
# (tree-shake elimina o código morto — sem custo de bundle).
# Crie projeto grátis em https://sentry.io e cole o DSN aqui.
# VITE_SENTRY_DSN=https://YOUR_KEY@oXXXXXX.ingest.sentry.io/YYYYYY

# --- Supabase Edge Functions (configure as project secrets, not in frontend) ---
# PAYMENT_PROVIDER_BASE_URL=
# PAYMENT_PROVIDER_API_KEY=
